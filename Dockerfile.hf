FROM python:3.12-slim

# Install system dependencies (Node.js, ffmpeg, OpenCV libs, curl)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

WORKDIR /app

# Install root Node dependencies and build the main frontend
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# Install Python requirements for moodtracker
WORKDIR /app/moodtracker
RUN pip install --no-cache-dir -r requirements.txt

# Install Python requirements for voice analysis
WORKDIR /app/Voice
RUN pip install --no-cache-dir -r requirements.txt
RUN python -c "import whisper; whisper.load_model('small')"

# Return to root workdir
WORKDIR /app

# Install tsx globally to run Express server
RUN npm install -g tsx typescript @types/node

# Make the startup script executable
RUN chmod +x start_space.sh

EXPOSE 7860
ENV PORT=7860
ENV NODE_ENV=production

CMD ["./start_space.sh"]
